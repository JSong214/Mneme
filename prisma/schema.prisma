generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id            String         @id @default(cuid())
  name          String
  description   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  documents     Document[]
  chunks        Chunk[]
  decisions     Decision[]
  actionItems   ActionItem[]
  openQuestions OpenQuestion[]
  risks         Risk[]
  askRuns       AskRun[]
  evalCases     EvalCase[]
  evalRuns      EvalRun[]

  @@map("projects")
}

model Document {
  id            String         @id @default(cuid())
  projectId     String
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fileName      String
  mimeType      String
  rawText       String
  status        DocumentStatus @default(PROCESSING)
  errorMessage  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  chunks        Chunk[]
  decisions     Decision[]
  actionItems   ActionItem[]
  openQuestions OpenQuestion[]
  risks         Risk[]

  @@index([projectId, createdAt])
  @@map("documents")
}

model Chunk {
  id         String                      @id @default(cuid())
  projectId  String
  project    Project                     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documentId String
  document   Document                    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content    String
  chunkIndex Int
  tokenCount Int
  embedding  Unsupported("vector(1536)")
  createdAt  DateTime                    @default(now())

  @@unique([documentId, chunkIndex])
  @@index([projectId])
  @@index([documentId])
  @@map("chunks")
}

model Decision {
  id           String    @id @default(cuid())
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documentId   String
  document     Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  title        String
  summary      String
  rationale    String?
  date         DateTime?
  participants String[]  @default([])
  sourceQuote  String
  createdAt    DateTime  @default(now())

  @@index([projectId])
  @@index([documentId])
  @@map("decisions")
}

model ActionItem {
  id          String           @id @default(cuid())
  projectId   String
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documentId  String
  document    Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  title       String
  description String
  owner       String?
  dueDate     DateTime?
  status      ActionItemStatus @default(OPEN)
  sourceQuote String
  createdAt   DateTime         @default(now())

  @@index([projectId])
  @@index([documentId])
  @@map("action_items")
}

model OpenQuestion {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documentId  String
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  question    String
  context     String
  owner       String?
  sourceQuote String
  createdAt   DateTime @default(now())

  @@index([projectId])
  @@index([documentId])
  @@map("open_questions")
}

model Risk {
  id          String       @id @default(cuid())
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documentId  String
  document    Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  title       String
  description String
  severity    RiskSeverity @default(MEDIUM)
  mitigation  String?
  sourceQuote String
  createdAt   DateTime     @default(now())

  @@index([projectId])
  @@index([documentId])
  @@map("risks")
}

model AskRun {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  question   String
  answerJson Json
  latencyMs  Int
  tokenUsage Json?
  createdAt  DateTime @default(now())

  @@index([projectId, createdAt])
  @@map("ask_runs")
}

model EvalCase {
  id              String    @id @default(cuid())
  projectId       String
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  question        String
  expectedSources String[]  @default([])
  expectedFacts   String[]  @default([])
  createdAt       DateTime  @default(now())
  runs            EvalRun[]

  @@index([projectId, createdAt])
  @@map("eval_cases")
}

model EvalRun {
  id                String   @id @default(cuid())
  projectId         String
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  evalCaseId        String
  evalCase          EvalCase @relation(fields: [evalCaseId], references: [id], onDelete: Cascade)
  answerJson        Json
  retrievedSources  Json
  sourceMatch       Boolean
  groundednessScore Int
  latencyMs         Int
  retrievalMode     RetrievalMode @default(BASELINE)
  retrievalMetrics  Json?
  tokenUsage        Json?
  createdAt         DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([evalCaseId, createdAt])
  @@map("eval_runs")
}

enum DocumentStatus {
  PROCESSING @map("processing")
  READY      @map("ready")
  FAILED     @map("failed")

  @@map("document_status")
}

enum ActionItemStatus {
  OPEN        @map("open")
  IN_PROGRESS @map("in_progress")
  DONE        @map("done")

  @@map("action_item_status")
}

enum RiskSeverity {
  LOW    @map("low")
  MEDIUM @map("medium")
  HIGH   @map("high")

  @@map("risk_severity")
}

enum RetrievalMode {
  BASELINE @map("baseline")
  RERANK   @map("rerank")

  @@map("retrieval_mode")
}
